# PostgreSQL (pgvector/pg17)
DATABASE_URL=postgres://aex:aex@localhost:5432/aex

# Redis
REDIS_URL=redis://localhost:6379

# API port
PORT=3001

# Anthropic API key (required for AI features)
ANTHROPIC_API_KEY=

# Auth session secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# API public URL
BETTER_AUTH_URL=http://localhost:3001

# Web app URL (for CORS)
CORS_ORIGIN=http://localhost:5173

# Encryption key for plugin credentials (generate with: openssl rand -hex 16)
# ENCRYPTION_KEY=
