    "ai": "^6.0.116",
    "better-auth": "^1.5.5",
    "bullmq": "^5.71.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.0",
